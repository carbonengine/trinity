struct VS_OUTPUT
{
	float4 Position : POSITION;
	float2 TexCoord : TEXCOORD;
};

sampler3D sampl: register( s0 );


struct PerObjectVSData
{
    float layer;
} PerObjectVS: register( ps, c0 );

float4 main(VS_OUTPUT In) : SV_Target
{
    return tex3D( sampl, float3( In.TexCoord, PerObjectVS.layer ) );
}