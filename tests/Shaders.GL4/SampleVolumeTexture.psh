#ifdef PS
uniform vec4 ssi;
in float ssv;
#endif

layout(location = 0) out vec4 FragColor;

in vec2 texCoord;

uniform vec4 cb7[1];

uniform sampler3D s0;

void main()
{
    FragColor = texture( s0, vec3( texCoord, cb7[0].x ) );
#ifdef PS
float av=floor(clamp(FragColor.a,0.0,1.0)*255.0+0.5);
if(ssi.z==0.0)
{
if(av*ssi.x+ssi.y<0.0)
discard;
}
else
{
if(ssi.x>0.0)
{
if(av==ssi.y)
discard;
}
else
{
if(av!=ssi.y)
discard;
}
}
if(ssv<0.0)discard;
#endif
}