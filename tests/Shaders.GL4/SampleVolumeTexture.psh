#ifdef PS
uniform vec4 ss[2];
#endif

layout(location = 0) out vec4 FragColor;

layout(location = 0) in vec2 texCoord;

uniform vec4 cb7[1];

uniform sampler3D s0;

void main()
{
    FragColor = texture( s0, vec3( texCoord, cb7[0].x ) );
#ifdef PS
if(ss[0].w!=0.0)
{
float av=floor(clamp(FragColor.a,0.0,1.0)*255.0+0.5);
if(ss[0].z==0.0)
{
if(av*ss[0].x+ss[0].y<0.0) discard;
}
else if(ss[0].x>0.0)
{
if(av==ss[0].y) discard;
}
else
{
if(av!=ss[0].y) discard;
}
}
#endif
}