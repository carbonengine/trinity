ProjectGuid: 504BC561-AF34-424A-82B7-D381566FA473
Imports:
- ../core_project/core_project.yaml

General:
  ConfigurationType: Application
  UseOfMfc: false
  IntDir: ../temp/$(ProjectName)/$(Platform)/$(Configuration)/$(PlatformToolset)/
  OutDir: ../../autobuild/TrinityALTest/$(Platform)/$(PlatformToolset)/
  TargetExt: .exe

ClCompile:
  CppExceptions: true
  EnableEnhancedInstructionSet: StreamingSIMDExtensions2
  DebugInformationFormat: OldStyle
  WarningLevel: Level3
  TreatWarningAsError: true
  BufferSecurityCheck: false
  PrecompiledHeader: Use
  PrecompiledHeaderFile: StdAfx.h
  PrecompiledHeaderOutputFile: $(IntDir)trinity.pch
  AdditionalIncludeDirectories:
  - .
  PreprocessorDefinitions:
  - TRINITY_AL_WITH_BLUE_EXPOSURE=0
  - NOMINMAX
  - BLUEBUILD

Link:
  GenerateDebugInformation: true
  ProgramDatabaseFile: $(TargetDir)$(TargetName).pdb

BaseConfigurations:
  Dev:
    UserMacros:
      CcpConfigType: Dev
    General:
      LinkIncremental: true
    ClCompile:
      PreprocessorDefinitions:
      - NDEBUG
      - CCP_ASSERT_ENABLED=1
      - TRINITYDEV
      Optimization: Disabled
      RuntimeLibrary: MultiThreadedDLL
      DebugInformationFormat: EditAndContinue

  Debug:
    UserMacros:
      CcpConfigType: Dev
    General:
      LinkIncremental: true
    ClCompile:
      PreprocessorDefinitions:
      - _DEBUG
      - CCP_ASSERT_ENABLED=1
      Optimization: Disabled
      RuntimeLibrary: MultiThreadedDebugDLL
      DebugInformationFormat: EditAndContinue

  Release:
    ClCompile:
      PreprocessorDefinitions:
      - NDEBUG
      Optimization: MaxSpeed
      RuntimeLibrary: MultiThreadedDLL

  D3D9:
    # These are settings that apply to all variants of Trinity that use D3D9
    Imports:
    - ../TrinityAL/uses_TrinityALDX9.yaml
    ClCompile:
      PreprocessorDefinitions:
      - NDEBUG

  D3D11:
    # These are settings that apply to all variants of Trinity that use D3D11
    Imports:
    - ../TrinityAL/uses_TrinityALDX11.yaml
    ClCompile:
      PreprocessorDefinitions:
      - D3DTARGET=9

  D3D12:
    # These are settings that apply to all variants of Trinity that use D3D11
    Imports:
    - ../TrinityAL/uses_TrinityALDX12.yaml

  Vulkan:
    # These are settings that apply to all variants of Trinity that use D3D11
    Imports:
    - ../TrinityAL/uses_TrinityALVulkan.yaml

  GLES2:
    # These are settings that apply to all variants of Trinity that use OpenGL ES 2
    Imports:
    - ../TrinityAL/uses_TrinityALGLES2.yaml
    ClCompile:
      PreprocessorDefinitions:
      - D3DTARGET=9

  STUB:
    # These are settings that apply to all variants of Trinity that use the stub
    Imports:
    - ../TrinityAL/uses_TrinityALStub.yaml
      
  WithGoogleTest:
    Imports:
    - ../../../vendor/GoogleTest/1.10.0/gtest.yaml
    ClCompile:
      PreprocessorDefinitions:
      - D3DTARGET=9

Configurations:
  Dev_DX9|Win32,x64:
    BaseConfigurations:
    - Dev
    - D3D9
    - WithGoogleTest
    General: 
      TargetName: TrinityALTestDX9_dev

  Release_DX9|Win32,x64:
    BaseConfigurations:
    - Release
    - D3D9
    - WithGoogleTest
    General:
      TargetName: TrinityALTestDX9

  Dev_DX11|Win32,x64:
    BaseConfigurations:
    - Dev
    - D3D11
    - WithGoogleTest
    General: 
      TargetName: TrinityALTestDX11_dev

  Release_DX11|Win32,x64:
    BaseConfigurations:
    - Release
    - D3D11
    - WithGoogleTest
    General:
      TargetName: TrinityALTestDX11

  Dev_GLES2|Win32,x64:
    BaseConfigurations:
    - Dev
    - GLES2
    - WithGoogleTest
    General: 
      TargetName: TrinityALTestGLES2_dev

  Debug_GLES2|Mac64:
    BaseConfigurations:
    - Debug
    - GLES2
    - WithGoogleTest
    General: 
      TargetName: TrinityALTestGLES2_dev

  Release_GLES2|Win32,x64,Mac64:
    BaseConfigurations:
    - Release
    - GLES2
    - WithGoogleTest
    General:
      TargetName: TrinityALTestGLES2


  Dev_STUB|Win32,x64:
    BaseConfigurations:
    - Dev
    - STUB
    - WithGoogleTest
    General: 
      TargetName: TrinityALTestSTUB_dev

  Debug_STUB|Mac64:
    BaseConfigurations:
    - Debug
    - STUB
    - WithGoogleTest
    General: 
      TargetName: TrinityALTestSTUB_d

  Release_STUB|Win32,x64,Mac64:
    BaseConfigurations:
    - Release
    - STUB
    - WithGoogleTest
    General:
      TargetName: TrinityALTestSTUB

  Dev_DX12|Win32,x64:
    BaseConfigurations:
    - Dev
    - D3D12
    - WithGoogleTest
    General: 
      TargetName: TrinityALTestDX12_dev

  Release_DX12|Win32,x64:
    BaseConfigurations:
    - Release
    - D3D12
    - WithGoogleTest
    General:
      TargetName: TrinityALTestDX12

  Dev_Vulkan|Win32,x64:
    BaseConfigurations:
    - Dev
    - Vulkan
    - WithGoogleTest
    General: 
      TargetName: TrinityALTestVulkan_dev

  Release_Vulkan|Win32,x64:
    BaseConfigurations:
    - Release
    - Vulkan
    - WithGoogleTest
    General:
      TargetName: TrinityALTestVulkan
